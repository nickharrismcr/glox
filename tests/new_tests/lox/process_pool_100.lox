import process;
import os;
import sys;

// Same design as process_pool.lox (in_flight[] correlates a wait_any()
// result back to its task index, so results land in task order regardless
// of which worker finishes first) but at the scale actually discussed: a
// fixed-size pool of workers pulling from a much larger task queue, so more
// than one full round of dispatch happens per worker and the pool stays
// saturated throughout.
here = os.dirname(sys.args()[0]);
worker_path = os.join(here, "process_pool_worker.lox");

n_workers = 4;
n_tasks = 100;
workers = [];
foreach (i in range(n_workers)) {
    workers.append(process.spawn(worker_path));
}

tasks = [];
foreach (i in range(1, n_tasks + 1)) {
    tasks.append(i);
}

results = [];
foreach (i in range(n_tasks)) {
    results.append(nil);
}

in_flight = [];
foreach (i in range(n_workers)) {
    in_flight.append(nil);
}

next_task = 0;
foreach (i in range(n_workers)) {
    workers[i].send(tasks[next_task]);
    in_flight[i] = next_task;
    next_task = next_task + 1;
}

outstanding = n_workers;
while (outstanding > 0) {
    idx, val = process.wait_any(workers);
    task_index = in_flight[idx];
    results[task_index] = val;
    if (next_task < n_tasks) {
        workers[idx].send(tasks[next_task]);
        in_flight[idx] = next_task;
        next_task = next_task + 1;
    } else {
        workers[idx].kill();
        outstanding = outstanding - 1;
    }
}

foreach (w in workers) {
    w.wait();
}

// Every task must have been dispatched exactly once and every result slot
// filled, regardless of scheduling order across the 4 workers.
missing = 0;
sum = 0;
foreach (r in results) {
    if (r == nil) {
        missing = missing + 1;
    } else {
        sum = sum + r;
    }
}

print len(results);
print missing;
print sum;
print results[0];
print results[n_tasks - 1];
print "done";
