// Regression test: `break` behind an unbraced `if (cond) break` (no extra
// scope level) at the same depth as the loop's own body. Before the fix,
// breakStatement() computed its cleanup-pop count from the parser's current
// scope depth rather than the loop's own fixed scope depth, and (for `for`
// loops specifically) patched the break jump onto the OP_LOOP back-edge
// instead of past the whole loop -- so break silently failed to exit,
// corrupted the stack, or hung. All existing tests happened to only exercise
// `if (cond) { break }` (braced), which sits one scope level deeper and
// masked the bug. See src/compiler/compile.go breakStatement()/forStatement().
total = 0
for (i = 0; i < 10; i = i + 1) {
    if (i == 3) break
    total = total + 1
}
print total

total2 = 0
i2 = 0
while (i2 < 10) {
    if (i2 == 3) break
    total2 = total2 + 1
    i2 = i2 + 1
}
print total2

total3 = 0
foreach (i3 in range(10)) {
    if (i3 == 3) break
    total3 = total3 + 1
}
print total3
