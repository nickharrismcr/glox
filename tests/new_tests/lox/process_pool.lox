import process;
import os;
import sys;

here = os.dirname(sys.args()[0]);
worker_path = os.join(here, "process_pool_worker.lox");

n_workers = 3;
workers = [];
foreach (i in range(n_workers)) {
    workers.append(process.spawn(worker_path));
}

// deliberately more tasks than workers, so at least one worker has to be
// fed a second/third task after finishing its first
tasks = [2, 3, 5, 7, 11, 13, 17, 19];
results = [];
foreach (i in range(len(tasks))) {
    results.append(nil);
}

in_flight = [];
foreach (i in range(n_workers)) {
    in_flight.append(nil);
}

next_task = 0;
foreach (i in range(n_workers)) {
    workers[i].send(tasks[next_task]);
    in_flight[i] = next_task;
    next_task = next_task + 1;
}

outstanding = n_workers;
while (outstanding > 0) {
    idx, val = process.wait_any(workers);
    task_index = in_flight[idx];
    results[task_index] = val;
    if (next_task < len(tasks)) {
        workers[idx].send(tasks[next_task]);
        in_flight[idx] = next_task;
        next_task = next_task + 1;
    } else {
        workers[idx].kill();
        outstanding = outstanding - 1;
    }
}

foreach (w in workers) {
    w.wait();
}

// print by task order, not arrival order, so the test is deterministic
// regardless of which worker happens to finish first
foreach (r in results) {
    print r;
}

print "done";
