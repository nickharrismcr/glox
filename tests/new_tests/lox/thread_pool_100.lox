import thread;

// The thread-module analogue of process_pool_100.lox: a fixed pool of
// workers (4) draining a much larger task queue (100), dispatched
// dynamically via wait_any as each worker frees up -- same design, same
// in_flight[] task-index correlation, just built on in-memory closures
// instead of a separate worker script/process per worker.
func worker() {
    var c = thread.channel();
    while (true) {
        var task = c.recv();
        c.send(task * task);
    }
}

n_workers = 4;
n_tasks = 100;

threads = [];
foreach (i in range(n_workers)) {
    threads.append(thread.spawn(worker));
}

tasks = [];
foreach (i in range(1, n_tasks + 1)) {
    tasks.append(i);
}

results = [];
foreach (i in range(n_tasks)) {
    results.append(nil);
}

in_flight = [];
foreach (i in range(n_workers)) {
    in_flight.append(nil);
}

next_task = 0;
foreach (i in range(n_workers)) {
    threads[i].send(tasks[next_task]);
    in_flight[i] = next_task;
    next_task = next_task + 1;
}

outstanding = n_workers;
while (outstanding > 0) {
    idx, val = thread.wait_any(threads);
    task_index = in_flight[idx];
    results[task_index] = val;
    if (next_task < n_tasks) {
        threads[idx].send(tasks[next_task]);
        in_flight[idx] = next_task;
        next_task = next_task + 1;
    } else {
        // No more tasks for this worker: cancel() unblocks its parked
        // channel().recv(). Mirrors process.kill() -- a cancelled
        // thread's wait() returns cleanly, it doesn't raise.
        threads[idx].cancel();
        outstanding = outstanding - 1;
    }
}

foreach (t in threads) {
    t.wait();
}

// Every task must have been dispatched exactly once and every result slot
// filled, regardless of scheduling order across the 4 threads.
missing = 0;
sum = 0;
foreach (r in results) {
    if (r == nil) {
        missing = missing + 1;
    } else {
        sum = sum + r;
    }
}

print len(results);
print missing;
print sum;
print results[0];
print results[n_tasks - 1];
print "done";
